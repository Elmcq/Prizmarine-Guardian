# ----------------------------------------------------------------------------
# Prizmarine Guardian — example environment configuration
# Copy to ".env" and edit:  cp .env.example .env
# ----------------------------------------------------------------------------

BOT_NAME=Prizmarine Guardian
PREFIX=!
OWNER=628xxxxxxxxxx
# OWNER_LID: Your WhatsApp LID (shown in bot logs as "@lid"). Only needed if
# the owner's group messages use LID privacy instead of the phone number.
# Run !help in a group and check logs for "LID resolved:" to find your LID.
# OWNER_LID=12345678901234@lid
WARN_LIMIT=3
BAN_DURATION=86400000
LOG_LEVEL=info

# Web dashboard (OPTIONAL). The dashboard only starts if DASHBOARD_TOKEN is
# set to a long, random string. Leave it empty to disable the dashboard.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
# Serve behind HTTPS (nginx reverse proxy) and firewall the port.
# DASHBOARD_PORT=3000
# DASHBOARD_HOST=0.0.0.0
# DASHBOARD_TOKEN=your_long_random_token_here

# Optional: pre-seed an invite link for a group so banned users receive a
# rejoin link when their ban expires. Replace GROUPID with the group's
# serialized id (e.g. 120363123456789012@g.us). Invite links are also
# auto-captured at startup when the bot is a group admin.
# INVITE_LINK_120363123456789012@g.us=https://chat.whatsapp.com/XXXXXXXXXXXX
